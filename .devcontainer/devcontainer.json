{
  "name": "Apresenta.AI",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:22",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "mounts": [
    "source=apresenta-ai-node-modules,target=${containerWorkspaceFolder}/node_modules,type=volume",
    "source=apresenta-ai-frontend-node-modules,target=${containerWorkspaceFolder}/frontend/node_modules,type=volume",
    "source=apresenta-ai-pnpm-store,target=${containerWorkspaceFolder}/.pnpm-store,type=volume"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "SuhelMakkad.shadcn-ui",
        "yoavbls.pretty-ts-errors"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        }
      }
    }
  },
  "postCreateCommand": "sudo chown node:node node_modules frontend/node_modules .pnpm-store && sudo corepack enable && pnpm install",
  "forwardPorts": [5173]
}
